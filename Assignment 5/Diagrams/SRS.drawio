        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nactor \&quot;Finance Department\&quot; as Scheduler\nactor \&quot;Operations Department\&quot; as Operation\nactor \&quot;Maintenance Department\&quot; as Maintenance\nactor \&quot;Traffic Control Department\&quot; as Traffic\nactor \&quot;Customer Service Department\&quot; as Customer\nactor \&quot;Resource Management Department\&quot; as Resource\nusecase \&quot;Accept/ Reject Financial Requests Of All Departments\&quot; as U1\nScheduler --&gt; U1\nU1 --&gt; Operation\nU1 --&gt; Maintenance\nU1 --&gt; Traffic\nU1 --&gt; Customer\nU1 --&gt; Resource\n\n\n\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="nrJnezS5qsvLhuJNMFa5-7">
