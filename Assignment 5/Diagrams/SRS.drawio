        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nclass System {\n  +accessDepartment()\n}\n\nclass User {\n  +userID: int\n  +name: String\n  +role: String\n  +login()\n  +requestData()\n}\n\nclass Engine {\n  +engineID: int\n  +location: String\n  +status: String\n  +trackEngine()\n}\n\nclass Schedule {\n  +scheduleID: int\n  +trainNumber: String\n  +departureTime: String\n  +arrivalTime: String\n  +updateTime()\n}\n\nclass Storage{\n  -Diesal_Barrels: int\n  -Steel_MetricTons: int\n  -Iron_MetricTons: int\n  +IncreaseStorage()\n  +ReduceStorage()\n}\n\nclass OperationsDepartment{\n  +reportProblem()\n  +requestPerformanceReport()\n}\n\nclass FinanceDepartment{\n  +acceptReport()\n  +rejectReport()\n}\n\nclass MaintenanceDepartment{\n  +acceptReport()\n  +rejectReport()\n}\n\nclass TrafficControlDepartment{\n  +requestDetailsOfTrain(Train obj)\n  +signalEmergecy(Train obj)\n}\n\nclass CustomerServiceDepartment{\n  +checkMessages()\n  +sendMessages()\n}\n\nclass ResourceManagementDepartment{\n  +showCurrentResources()\n  +orderMoreResources()\n}\n\nclass Train{\n  -modelNo: stirng\n  -departure: string\n  -arrival: string\n}\n\nSystem *-- OperationsDepartment : composed\nSystem *-- ResourceManagementDepartment: composed\nSystem *-- CustomerServiceDepartment: composed\nSystem *-- TrafficControlDepartment: composed\nSystem *-- MaintenanceDepartment: composed\nSystem *-- FinanceDepartment: composed\n\nTrain *-- Engine\n\nTrafficControlDepartment *-- Schedule \n\nOperationsDepartment o-- Train\nTrafficControlDepartment o-- Train\nMaintenanceDepartment o-- Train\nResourceManagementDepartment o-- Storage\nSchedule o-- Train\nSystem o-- User\n\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="nrJnezS5qsvLhuJNMFa5-10">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" parent="1" vertex="1">
            <mxGeometry x="240" y="1040" width="1259" height="858" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nactor User\n\nrectangle System {\n  (Access Departments)\n  (Track Engine)\n  (Manage Schedule)\n  (Handle Resources)\n  (Customer Messages)\n  (Manage Reports)\n  (Handle Emergency)\n}\n\nUser --&gt; (Access Departments) : Login / Request Data\n(Access Departments) --&gt; (Manage Schedule) : Request Schedule Updates\n(Manage Schedule) --&gt; Schedule : Update Schedule\n(Manage Schedule) --&gt; Train : Fetch Train Details\n(Track Engine) --&gt; Train : Monitor Engine Status\n(Handle Resources) --&gt; Storage : Update / Fetch Resources\n(Handle Emergency) --&gt; Train : Send Emergency Signal\n(Handle Emergency) --&gt; Schedule : Request Train Details\n(Manage Reports) --&gt; (Handle Emergency) : Report Issues\n(Manage Reports) --&gt; Train : Fetch Performance Data\n(Manage Reports) --&gt; Storage : Fetch Resource Usage\n(Customer Messages) --&gt; User : Receive / Send Messages\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="nrJnezS5qsvLhuJNMFa5-11">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" parent="1" vertex="1">
            <mxGeometry x="1750" y="1530" width="1260" height="519" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nactor \&quot;User\&quot; as U\nparticipant \&quot;Operations Department\&quot; as OD\nparticipant \&quot;Finance Department\&quot; as FD\nparticipant \&quot;Customer Service Department\&quot; as CSD\nparticipant \&quot;Traffic Control Department\&quot; as TCD\nparticipant \&quot;Maintenance Department\&quot; as MD\n\nU -&gt; OD: Log in\nOD -&gt; FD: Request financial data\nactivate FD\nFD -&gt; FD: Review financial request\nalt Request accepted\n  FD -&gt; OD: Accept request\nelse Request rejected\n  FD -&gt; OD: Reject request\nend\ndeactivate FD\n\nU -&gt; OD: Log in\nOD -&gt; CSD: Request customer service data\nactivate CSD\nCSD -&gt; CSD: Review customer complaints\nalt Complaints resolved\n  CSD -&gt; OD: Accept complaints\nelse Complaints unresolved\n  CSD -&gt; OD: Reject complaints\nend\ndeactivate CSD\n\nU -&gt; OD: Log in\nOD -&gt; TCD: Request train traffic data\nactivate TCD\nTCD -&gt; TCD: Review traffic data\nalt Data accurate\n  TCD -&gt; OD: Accept data\nelse Data inaccurate\n  TCD -&gt; OD: Reject data\nend\ndeactivate TCD\n\nU -&gt; OD: Log in\nOD -&gt; MD: Request maintenance report\nactivate MD\nMD -&gt; MD: Review maintenance report\nalt Report accepted\n  MD -&gt; OD: Accept report\nelse Report rejected\n  MD -&gt; OD: Reject report\nend\ndeactivate MD\n\nOD -&gt; OD: Monitor and manage department statuses\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="k4qU3tgIN6w27e8FUr-n-1">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1" parent="1">
            <mxGeometry x="-190" y="2248" width="1179" height="1005" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nentity User {\n    +UserID : int\n    +UserName : string\n    +Password : string\n}\n\nentity OperationsDepartment {\n    +OpDeptID : int\n    +DeptName : string\n}\n\nentity FinanceDepartment {\n    +FinDeptID : int\n    +DeptName : string\n}\n\nentity CustomerServiceDepartment {\n    +CustDeptID : int\n    +DeptName : string\n}\n\nentity TrafficControlDepartment {\n    +TraDeptID : int\n    +DeptName : string\n}\n\nentity MaintenanceDepartment {\n    +MainDeptID : int\n    +DeptName : string\n}\n\nentity Request {\n    +RequestID : int\n    +DeptID : int\n    +Amount : float\n    +Reason : string\n    +Status : string\n}\n\nUser \&quot;1\&quot; -- \&quot;1\&quot; OperationsDepartment\nUser \&quot;1\&quot; -- \&quot;1\&quot; FinanceDepartment\nUser \&quot;1\&quot; -- \&quot;1\&quot; CustomerServiceDepartment\nUser \&quot;1\&quot; -- \&quot;1\&quot; TrafficControlDepartment\nUser \&quot;1\&quot; -- \&quot;1\&quot; MaintenanceDepartment\nOperationsDepartment \&quot;1\&quot; -- \&quot;1..*\&quot; Request\nFinanceDepartment \&quot;1\&quot; -- \&quot;1..*\&quot; Request\nCustomerServiceDepartment \&quot;1\&quot; -- \&quot;1..*\&quot; Request\nTrafficControlDepartment \&quot;1\&quot; -- \&quot;1..*\&quot; Request\nMaintenanceDepartment \&quot;1\&quot; -- \&quot;1..*\&quot; Request\n\nOperationsDepartment --|&gt; FinanceDepartment\nOperationsDepartment --|&gt; CustomerServiceDepartment\nOperationsDepartment --|&gt; TrafficControlDepartment\nOperationsDepartment --|&gt; MaintenanceDepartment\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="k4qU3tgIN6w27e8FUr-n-2">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1" parent="1">
            <mxGeometry x="-190" y="3300" width="934" height="565" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startdfd\nexternal_entity(User as \&quot;Operations Department\&quot;)\nexternal_entity(Maintenance as \&quot;Maintenance Department\&quot;)\nprocess(Request as \&quot;Request Maintenance Report\&quot;)\nprocess(Generate as \&quot;Generate Maintenance Report\&quot;)\nprocess(Upload as \&quot;Upload Report\&quot;)\nprocess(Review as \&quot;Review Report\&quot;)\ndataflow(Request, Generate, \&quot;Maintenance Request\&quot;)\ndataflow(Generate, Upload, \&quot;Maintenance Report\&quot;)\ndataflow(Upload, Review, \&quot;Uploaded Report\&quot;)\ndataflow(Review, Request, \&quot;Accepted/Rejected Report\&quot;)\n@enddfd\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="k4qU3tgIN6w27e8FUr-n-3">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1" parent="1">
            <mxGeometry x="770" y="3630" width="371" height="22" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n!define RECTANGLE class\n&#39; Users and Departments\nrectangle \&quot;User\&quot; {\n    RECTANGLE User {\n        +UserID : int\n        +UserName : string\n        +Password : string\n    }\n}\n\nrectangle \&quot;Departments\&quot; {\n    RECTANGLE OperationsDepartment {\n        +OpDeptID : int\n        +DeptName : string\n    }\n\n    RECTANGLE FinanceDepartment {\n        +FinDeptID : int\n        +DeptName : string\n    }\n\n    RECTANGLE CustomerServiceDepartment {\n        +CustDeptID : int\n        +DeptName : string\n    }\n\n    RECTANGLE TrafficControlDepartment {\n        +TraDeptID : int\n        +DeptName : string\n    }\n\n    RECTANGLE MaintenanceDepartment {\n        +MainDeptID : int\n        +DeptName : string\n    }\n}\n\nrectangle \&quot;Requests\&quot; {\n    RECTANGLE Request {\n        +RequestID : int\n        +DeptID : int\n        +Amount : float\n        +Reason : string\n        +Status : string\n    }\n}\n\n&#39; Relationships\nUser -- OperationsDepartment : Manages\nUser -- FinanceDepartment : Manages\nUser -- CustomerServiceDepartment : Manages\nUser -- TrafficControlDepartment : Manages\nUser -- MaintenanceDepartment : Manages\n\nOperationsDepartment -- FinanceDepartment : Controls\nOperationsDepartment -- CustomerServiceDepartment : Controls\nOperationsDepartment -- TrafficControlDepartment : Controls\nOperationsDepartment -- MaintenanceDepartment : Controls\n\nFinanceDepartment -- Request : Handles\nCustomerServiceDepartment -- Request : Handles\nTrafficControlDepartment -- Request : Handles\nMaintenanceDepartment -- Request : Handles\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="k4qU3tgIN6w27e8FUr-n-4">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1" parent="1">
