        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nactor \&quot;Resource Management Department\&quot; as Scheduler\nusecase \&quot;Manage Resources\&quot; as U1\nScheduler --&gt; U1\n\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="nrJnezS5qsvLhuJNMFa5-9">
