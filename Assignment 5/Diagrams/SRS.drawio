          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ncomponent User {\n    [User]\n}\n\ncomponent OperationsDepartment {\n    [OperationsDepartment]\n}\n\ncomponent FinanceDepartment {\n    [FinanceDepartment]\n}\n\ncomponent CustomerServiceDepartment {\n    [CustomerServiceDepartment]\n}\n\ncomponent TrafficControlDepartment {\n    [TrafficControlDepartment]\n}\n\ncomponent MaintenanceDepartment {\n    [MaintenanceDepartment]\n}\n\ncomponent Request {\n    [Request]\n}\n\n&#39; Relationships\nUser --&gt; OperationsDepartment : Manages\nUser --&gt; FinanceDepartment : Manages\nUser --&gt; CustomerServiceDepartment : Manages\nUser --&gt; TrafficControlDepartment : Manages\nUser --&gt; MaintenanceDepartment : Manages\n\nOperationsDepartment --&gt; FinanceDepartment : Controls\nOperationsDepartment --&gt; CustomerServiceDepartment : Controls\nOperationsDepartment --&gt; TrafficControlDepartment : Controls\nOperationsDepartment --&gt; MaintenanceDepartment : Controls\n\nFinanceDepartment --&gt; Request : Handles\nCustomerServiceDepartment --&gt; Request : Handles\nTrafficControlDepartment --&gt; Request : Handles\nMaintenanceDepartment --&gt; Request : Handles\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="k4qU3tgIN6w27e8FUr-n-6">
